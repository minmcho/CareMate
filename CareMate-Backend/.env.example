# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=caremate

# VLLM (run: python -m vllm.entrypoints.openai.api_server --model mistralai/Mistral-7B-Instruct-v0.3)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Speech-to-Text
STT_DEVICE=cuda   # or cpu

# Redis (reasoning memory cache)
REDIS_URL=redis://localhost:6379
MEMORY_CACHE_TTL=3600

# Optional: Anthropic / OpenAI fallback keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","*"]
