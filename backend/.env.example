# VitalPath AI backend environment
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://vitalpath:vitalpath@localhost:5432/vitalpath

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=user_wellness_context

# Supabase auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=change-me

# Model endpoints
LLAMA4_ENDPOINT=http://localhost:11434/api/generate
LLAMA4_MODEL=llama-4-8b-instruct
QWEN_TEXT_ENDPOINT=http://localhost:11435/api/generate
QWEN_TEXT_MODEL=qwen3.5-32b
QWEN_VL_ENDPOINT=http://localhost:11436/api/generate
QWEN_VL_MODEL=qwen3.5-vl-7b

# Safety switches
ENABLE_CRISIS_ESCALATION=true
ENABLE_MEDICAL_REWRITE=true
